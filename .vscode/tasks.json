{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build BlindCode",
      "type": "shell",
      "command": "node esbuild.js",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "Watch BlindCode",
      "type": "shell",
      "command": "node esbuild.js --watch",
      "group": "build",
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"]
    }
  ]
}
